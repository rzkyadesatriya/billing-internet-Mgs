    <a href="/admin/genieacs" class="<%= typeof page !== 'undefined' && page === 'genieacs' ? 'active' : '' %>">
        <i class="bi bi-hdd-network"></i> GenieACS
    </a>
    <a href="/admin/mikrotik" class="<%= typeof page !== 'undefined' && (page === 'mikrotik' || page === 'mikrotik-profiles' || page === 'hotspot-profiles' || page === 'hotspot' || page === 'voucher') ? 'active' : '' %>">
        <i class="bi bi-router"></i> Mikrotik
