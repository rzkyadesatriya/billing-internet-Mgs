        </button>
    </div>
    
    <!-- Logo Section -->
    <div class="sidebar-header mb-4 text-center">
        <div class="company-info mt-2">
            <h6 class="company-name mb-1">
                <%= (settings && settings.company_header) ? settings.company_header : ((typeof versionInfo !== 'undefined' && versionInfo.companyHeader) ? versionInfo.companyHeader : 'MGS-Billing') %>
            </h6>
        </div>
    </div>
    
    <!-- Navigation Links -->
    <a href="/admin/dashboard" class="<%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">
        <i class="bi bi-house"></i> Dashboard
    </a>
    <a href="/admin/billing/dashboard" class="<%= typeof page !== 'undefined' && page === 'billing' ? 'active' : '' %>">
        <i class="bi bi-receipt"></i> Billing
    </a>
    <a href="/admin/agents" class="<%= typeof page !== 'undefined' && page === 'agents' ? 'active' : '' %>">
        <i class="bi bi-person-badge-fill"></i> Web Agent
    </a>
    <a href="/admin/technicians" class="<%= typeof page !== 'undefined' && (page === 'technicians' || page === 'installations') ? 'active' : '' %>">
        <i class="bi bi-people-fill"></i> Teknisi & Instalasi
    </a>
    <a href="/admin/cable-network/odp" class="<%= typeof page !== 'undefined' && (page === 'cable-network-odp' || page === 'cable-network-cables' || page === 'cable-network-analytics') ? 'active' : '' %>">
