<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Pelanggan | Portal ISP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --menu-light: #F5F7FB;
      --menu-blue: #1F4E8C;
      --menu-accent: #00A37A;
    }
    body {
      background: linear-gradient(135deg, var(--menu-blue) 0%, var(--menu-accent) 100%);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      padding-top: 80px; /* Kompensasi untuk navbar fixed */
    }
    .login-card {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border: none;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      max-width: 400px;
      width: 100%;
    }
    .login-header {
      background: linear-gradient(135deg, var(--menu-blue) 0%, var(--menu-accent) 100%);
      color: white;
      padding: 30px 20px;
      text-align: center;
    }
    .form-container {
      padding: 30px 25px;
    }
    .form-floating {
      margin-bottom: 20px;
    }
    .form-control {
      border: 2px solid #F5F7FB;
      border-radius: 12px;
      padding: 15px 20px;
      font-size: 16px;
      transition: all 0.3s ease;
    }
    .form-control:focus {
      border-color: var(--menu-blue);
      box-shadow: 0 0 0 0.2rem rgba(74, 139, 223, 0.25);
    }
    .btn-login {
      background: linear-gradient(135deg, var(--menu-blue) 0%, var(--menu-accent) 100%);
      border: none;
      border-radius: 12px;
      padding: 15px;
      font-size: 16px;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(160, 0, 109, 0.25);
    }
    .footer-text {
      color: #6c757d;
      font-size: 12px;
      margin-top: 20px;
    }
    @media (max-width: 576px) {
      .login-container {
        padding: 10px;
      }
      .login-card {
        border-radius: 15px;
      }
      .form-container {
        padding: 25px 20px;
      }
    }
  </style>
</head>
<body>
  <div class="login-container">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light position-fixed top-0 start-0 w-100" style="z-index: 1000; background: #F5F7FB; border-bottom: 1px solid rgba(74,139,223,.35); backdrop-filter: blur(10px);">
      <div class="container">
        <a class="navbar-brand" href="/">
          Portal Pelanggan
        </a>
        <div class="navbar-nav ms-auto">
          <!-- Tombol admin login dihilangkan -->
        </div>
      </div>
    </nav>
    
    <div class="login-card">
      <div class="login-header">
        <h4 class="mb-1 fw-bold">Portal Pelanggan</h4>
        <p class="mb-0 opacity-75"><%= settings.company_header %></p>
      </div>
      <div class="form-container">
        <form id="loginForm" action="/customer/login" method="POST">
          <div class="form-floating">
            <input type="text" class="form-control" id="phone" name="phone" placeholder="Nomor HP" required autofocus pattern="(08[0-9]{8,13}|\+?62[0-9]{8,13})">
            <label for="phone">
              <i class="bi bi-phone me-2"></i>Nomor HP
            </label>
          </div>
          <div class="form-floating">
            <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
            <label for="password">
              <i class="bi bi-lock me-2"></i>Password
            </label>
          </div>
          <button type="submit" class="btn btn-primary btn-login w-100" id="loginBtn">
            <span class="btn-text">
              <i class="bi bi-box-arrow-in-right me-2"></i>Masuk
            </span>
            <span class="btn-loading" style="display:none;">
              <i class="bi bi-hourglass-split me-2"></i>Memproses...
            </span>
          </button>
        </form>
        <div id="loginAlert" style="display:none;"></div>
        <div class="text-center footer-text">
          <!-- Agent Registration Link -->
          <div class="mb-3">
            <h6 class="mb-2 text-muted">Ingin jadi Agent?</h6>
            <a href="/agent/login" class="btn btn-outline-success btn-sm">
              <i class="bi bi-person-plus me-2"></i>
              Daftar Agent Mandiri
            </a>
            <p class="small text-muted mt-2 mb-3">
              <i class="bi bi-info-circle me-1"></i>
              Daftar sekarang dan mulai transaksi setelah deposit
            </p>
          </div>
          
          <hr class="my-3">
          
          <p class="mb-2">
            <i class="bi bi-shield-check me-1"></i>
            Sistem keamanan terjamin
          </p>
          <p class="mb-2">
            <i class="bi bi-telephone me-1"></i>
            Butuh bantuan? Hubungi <%= settings.contact_phone || 'Admin' %>
          </p>
          
          <p class="mb-0">
            &copy; <%= new Date().getFullYear() %> <%= typeof settings !== 'undefined' && settings.footer_info ? settings.footer_info : 'MAYA GLOBAL SOLUTION' %>
          </p>
        </div>
      </div>
    </div>
  </div>
  <!-- Toast Container -->
  <div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>

  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // Fungsi toast notification
    function showToast(type, title, message, duration = 5000) {
        const toastId = 'toast-' + Date.now();
        const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
        const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
        
        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 300px;">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconClass} me-2"></i>
                        <strong>${title}</strong><br>
                        <small>${message}</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        `;
        
        $('#toast-container').append(toastHtml);
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { delay: duration });
        toast.show();
        
        // Auto remove after hide
        toastElement.addEventListener('hidden.bs.toast', () => {
            toastElement.remove();
        });
    }

    // Handler form login
    $('#loginForm').on('submit', function(e) {
        e.preventDefault();
        
        const phone = $('#phone').val();
        const password = $('#password').val();
        
        if (!phone || !phone.match(/^(08[0-9]{8,13}|\+?62[0-9]{8,13})$/)) {
            showToast('error', 'Error', 'Nomor HP harus valid (08..., 62..., atau +62...)');
            return;
        }

        if (!password) {
            showToast('error', 'Error', 'Password harus diisi');
            return;
        }
        
        // Loading state
        const $btn = $('#loginBtn');
        const $btnText = $btn.find('.btn-text');
        const $btnLoading = $btn.find('.btn-loading');
        
        $btn.prop('disabled', true);
        $btnText.hide();
        $btnLoading.show();
        
        // Kirim request
        $.ajax({
            url: '/customer/login',
            method: 'POST',
            data: { phone, password },
            success: function(response) {
                if (response.success) {
                    const target = response.redirect || '/customer/dashboard';
                    showToast('success', 'Login Berhasil', 'Mengalihkan...');
                    setTimeout(() => {
                        window.location.href = target;
                    }, 800);
                } else {
                    showToast('error', 'Login Gagal', response.message || 'Nomor HP tidak terdaftar');
                }
            },
            error: function(xhr) {
                const errorMsg = xhr.responseJSON?.message || 'Terjadi kesalahan saat login';
                showToast('error', 'Error', errorMsg);
            },
            complete: function() {
                // Reset button
                $btn.prop('disabled', false);
                $btnText.show();
                $btnLoading.hide();
            }
        });
    });

    // Hindari loop/nyangkut redirect akibat service worker lama
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then(function(regs) {
            regs.forEach(function(reg) { reg.unregister(); });
        }).catch(function() {});
    }
    if (window.caches && caches.keys) {
        caches.keys().then(function(keys) {
            keys.forEach(function(k) {
                if (k && k.indexOf('pwa-static') !== -1) {
                    caches.delete(k).catch(function() {});
                }
            });
        }).catch(function() {});
    }

  </script>
</body>
</html> 



